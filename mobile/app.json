{
  "expo": {
    "name": "CartaAI",
    "slug": "cartaAI",
    "owner": "cartaai",
    "scheme": "cartaai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_cartaAI.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.cartaai.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo_cartaAI.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 3
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_cartaAI.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_cartaAI.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7265d59c-85d8-4ecf-a719-ee9969309482"
      }
    }
  }
}
